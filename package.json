{
  "name": "tailwind-css",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "serve": "live-server --port=3000 --no-browser",
    "dev": "concurrently -n css,server -c yellow,cyan \"npm run watch:css\" \"npm run serve\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "concurrently": "^10.0.3",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.3.1"
  }
}
